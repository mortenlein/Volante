<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        Title="Volante" Height="740" Width="920"
        WindowStartupLocation="CenterScreen" Background="#0F1117" FontFamily="Segoe UI">

  <Window.Resources>
    <CollectionViewSource x:Key="TweakView">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="Category"/>
      </CollectionViewSource.GroupDescriptions>
      <CollectionViewSource.SortDescriptions>
        <scm:SortDescription PropertyName="Category"/>
        <scm:SortDescription PropertyName="Name"/>
      </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>

    <!-- Default flat button -->
    <Style TargetType="Button">
      <Setter Property="Foreground" Value="#E6E8EE"/>
      <Setter Property="Background" Value="#2A3142"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Background" Value="#39435C"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Primary accent button -->
    <Style TargetType="Button" x:Key="Accent">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Background" Value="#3E7BFA"/>
      <Setter Property="Padding" Value="20,10"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Background" Value="#5790FF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Subtle text/link button -->
    <Style TargetType="Button" x:Key="Link">
      <Setter Property="Foreground" Value="#8A90A2"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#D6DAE6"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0" Background="#161A24" Padding="24,16">
      <Grid>
        <StackPanel>
          <TextBlock Text="Volante" Foreground="#FFFFFF" FontSize="22" FontWeight="SemiBold"/>
          <TextBlock x:Name="HeaderSubtitle" Text="Let's tune your PC for gaming"
                     Foreground="#8A90A2" FontSize="13"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===================== CONTENT HOST ===================== -->
    <Grid Grid.Row="1">

      <!-- ============ DASHBOARD PAGE (landing) ============ -->
      <Grid x:Name="PageDashboard">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Width="680" Margin="0,24" HorizontalAlignment="Center">
            <TextBlock Text="System check" Foreground="#E6E8EE" FontSize="20"
                       FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="A quick look at your setup before we tune anything. Everything here is read-only - the only change is the optional refresh-rate fix, which you confirm."
                       Foreground="#8A90A2" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,18"/>

            <!-- Card: refresh rate -->
            <Border Background="#1A1E29" CornerRadius="10" Padding="16" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="MONITOR REFRESH RATE" Foreground="#5B86FF" FontSize="12"
                           FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel x:Name="DashRefreshPanel"/>
              </StackPanel>
            </Border>

            <!-- Card: GPU driver -->
            <Border Background="#1A1E29" CornerRadius="10" Padding="16" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="GPU DRIVER" Foreground="#5B86FF" FontSize="12"
                           FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel x:Name="DashDriverPanel"/>
                <Button x:Name="BtnWindowsUpdate" Content="Open Windows Update"
                        Style="{StaticResource Link}" HorizontalAlignment="Left" Margin="0,6,0,0"/>
              </StackPanel>
            </Border>

            <!-- Card: Valve ping -->
            <Border Background="#1A1E29" CornerRadius="10" Padding="16" Margin="0,0,0,12">
              <StackPanel>
                <Grid Margin="0,0,0,8">
                  <TextBlock Text="PING TO VALVE / STEAM" Foreground="#5B86FF" FontSize="12"
                             FontWeight="Bold" VerticalAlignment="Center"/>
                  <Button x:Name="BtnPingRetest" Content="Re-test" Style="{StaticResource Link}"
                          HorizontalAlignment="Right"/>
                </Grid>
                <StackPanel x:Name="DashPingPanel"/>
                <TextBlock Text="TCP handshake latency to Steam edge endpoints - a routing-latency proxy, not your exact in-game ping (CS2 relays don't answer pings)."
                           Foreground="#6A7080" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>
              </StackPanel>
            </Border>

            <!-- Card: CS2 control-panel settings -->
            <Border Background="#1A1E29" CornerRadius="10" Padding="16" Margin="0,0,0,12">
              <StackPanel>
                <Grid Margin="0,0,0,8">
                  <TextBlock x:Name="DashCpHeader" Text="CS2 GPU CONTROL-PANEL SETTINGS"
                             Foreground="#5B86FF" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                  <Button x:Name="BtnCpOpen" Content="Open control panel"
                          HorizontalAlignment="Right"/>
                </Grid>
                <StackPanel x:Name="DashCpPanel"/>
                <TextBlock Text="Recommended CS2 settings. 'Verify in control panel' means the value can't be read safely from outside the driver - open the panel to set it."
                           Foreground="#6A7080" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>
              </StackPanel>
            </Border>

            <!-- Footer actions -->
            <Grid Margin="0,8,0,0">
              <Button x:Name="BtnDashRecheck" Content="Re-run checks" Style="{StaticResource Link}"
                      HorizontalAlignment="Left"/>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnDashAdvanced" Content="Advanced mode" Style="{StaticResource Link}"/>
                <Button x:Name="BtnDashStart" Content="Start tuning" Style="{StaticResource Accent}"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </Grid>

      <!-- ============ WIZARD PAGE ============ -->
      <Grid x:Name="PageWizard" Visibility="Collapsed">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <Grid>
            <!-- Step 1: Goals -->
            <StackPanel x:Name="StepGoals" Width="640" Margin="0,28" HorizontalAlignment="Center">
              <TextBlock Text="What would you like to improve?" Foreground="#E6E8EE"
                         FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
              <TextBlock Text="Pick one or both. Both are selected by default - that's our recommendation."
                         Foreground="#8A90A2" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,18"/>

              <Border Background="#1A1E29" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                <StackPanel>
                  <CheckBox x:Name="ChkPerf" IsChecked="True" Foreground="#E6E8EE" FontSize="16">
                    <TextBlock Text="Gaming performance" FontWeight="SemiBold"/>
                  </CheckBox>
                  <TextBlock Text="Lower input lag, steadier frame pacing, full-power settings, and less background activity while you play."
                             Foreground="#9AA0B2" FontSize="13" TextWrapping="Wrap" Margin="26,6,0,0"/>
                </StackPanel>
              </Border>

              <Border Background="#1A1E29" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                <StackPanel>
                  <CheckBox x:Name="ChkPriv" IsChecked="True" Foreground="#E6E8EE" FontSize="16">
                    <TextBlock Text="Privacy &amp; less clutter" FontWeight="SemiBold"/>
                  </CheckBox>
                  <TextBlock Text="Turn off ad tracking, tailored ads, activity history, web results in search, and Start-menu app suggestions."
                             Foreground="#9AA0B2" FontSize="13" TextWrapping="Wrap" Margin="26,6,0,0"/>
                </StackPanel>
              </Border>

              <Grid Margin="0,16,0,0">
                <Button x:Name="BtnToAdvanced" Content="Power user? Open Advanced mode"
                        Style="{StaticResource Link}" HorizontalAlignment="Left"/>
                <Button x:Name="BtnGoalsNext" Content="Next" Style="{StaticResource Accent}"
                        HorizontalAlignment="Right"/>
              </Grid>
            </StackPanel>

            <!-- Step 2: Review -->
            <StackPanel x:Name="StepReview" Width="640" Margin="0,28" HorizontalAlignment="Center"
                        Visibility="Collapsed">
              <TextBlock Text="Here's what we'll do" Foreground="#E6E8EE"
                         FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
              <TextBlock x:Name="ReviewSummary" Foreground="#8A90A2" FontSize="13"
                         TextWrapping="Wrap" Margin="0,0,0,16"/>

              <Border Background="#1A1E29" CornerRadius="10" Padding="6" MaxHeight="320">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <ItemsControl x:Name="ReviewList">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="14,7">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="+" Foreground="#3E7BFA"
                                     FontWeight="Bold" Margin="0,0,10,0"/>
                          <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#D6DAE6"
                                     FontSize="13" TextWrapping="Wrap"/>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>

              <TextBlock Text="A System Restore point is saved automatically first, and you can undo everything later."
                         Foreground="#2E9E5B" FontSize="12" TextWrapping="Wrap" Margin="2,12,0,0"/>

              <Grid Margin="0,16,0,0">
                <Button x:Name="BtnReviewBack" Content="Back" Style="{StaticResource Link}"
                        HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <Button x:Name="BtnPreviewWizard" Content="Preview (no changes)"/>
                  <Button x:Name="BtnApplyWizard" Content="Apply improvements" Style="{StaticResource Accent}"/>
                </StackPanel>
              </Grid>
            </StackPanel>

            <!-- Step 3: Results -->
            <StackPanel x:Name="StepResults" Width="640" Margin="0,28" HorizontalAlignment="Center"
                        Visibility="Collapsed">
              <TextBlock x:Name="ResultsTitle" Text="All done!" Foreground="#E6E8EE"
                         FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <Border Background="#1A1E29" CornerRadius="10" Padding="18">
                <TextBlock x:Name="ResultsText" Foreground="#D6DAE6" FontSize="14"
                           TextWrapping="Wrap" LineHeight="22"/>
              </Border>
              <Grid Margin="0,18,0,0">
                <Button x:Name="BtnUndoAll" Content="Undo everything" Style="{StaticResource Link}"
                        HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <Button x:Name="BtnRestart" Content="Restart now" Visibility="Collapsed"/>
                  <Button x:Name="BtnApplyNow" Content="Apply these now" Style="{StaticResource Accent}"
                          Visibility="Collapsed"/>
                  <Button x:Name="BtnDone" Content="Done"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Grid>
        </ScrollViewer>
      </Grid>

      <!-- ============ ADVANCED PAGE ============ -->
      <Grid x:Name="PageAdvanced" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="140"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Margin="18,14,18,4" LastChildFill="False">
          <Button x:Name="BtnToSimple" Content="&#x2190; Dashboard" Style="{StaticResource Link}"
                  DockPanel.Dock="Left"/>
          <Button x:Name="BtnApply" Content="Apply Selected" Style="{StaticResource Accent}"
                  DockPanel.Dock="Right"/>
          <Button x:Name="BtnRefresh" Content="Refresh" DockPanel.Dock="Right"/>
          <Button x:Name="BtnRevert"  Content="Revert Selected" DockPanel.Dock="Right"/>
          <Button x:Name="BtnDryRun"  Content="Dry Run" DockPanel.Dock="Right"/>
          <Button x:Name="BtnRestore" Content="Restore Point" DockPanel.Dock="Right"/>
          <Button x:Name="BtnNone"    Content="Clear" DockPanel.Dock="Right"/>
          <Button x:Name="BtnAll"     Content="All" DockPanel.Dock="Right"/>
          <Button x:Name="BtnRecommended" Content="Recommended" DockPanel.Dock="Right"/>
        </DockPanel>

        <!-- List -->
        <ScrollViewer Grid.Row="1" Margin="18,4" VerticalScrollBarVisibility="Auto">
          <ItemsControl x:Name="TweakList" ItemsSource="{Binding Source={StaticResource TweakView}}">
            <ItemsControl.GroupStyle>
              <GroupStyle>
                <GroupStyle.HeaderTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}" Foreground="#5B86FF" FontSize="12"
                               FontWeight="Bold" Margin="2,12,0,4"/>
                  </DataTemplate>
                </GroupStyle.HeaderTemplate>
              </GroupStyle>
            </ItemsControl.GroupStyle>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="#1A1E29" CornerRadius="8" Padding="14,12" Margin="0,5">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding Name}" Foreground="#E6E8EE" FontSize="14" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Description}" Foreground="#9AA0B2" TextWrapping="Wrap"
                                 Margin="0,3,12,0" FontSize="12"/>
                      <TextBlock Text="{Binding StateText}" Foreground="{Binding StateColor}"
                                 FontStyle="Italic" Margin="0,5,0,0" FontSize="11"/>
                    </StackPanel>
                    <Border Grid.Column="2" Background="{Binding RiskColor}" CornerRadius="10"
                            Padding="9,3" VerticalAlignment="Top" Height="22">
                      <TextBlock Text="{Binding Risk}" Foreground="White" FontSize="11"/>
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Log -->
        <Border Grid.Row="2" Background="#0A0C12" CornerRadius="8" Margin="18,4,18,8">
          <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Padding="10,8">
            <TextBox x:Name="LogBox" Background="Transparent" Foreground="#86E58B" BorderThickness="0"
                     IsReadOnly="True" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
          </ScrollViewer>
        </Border>
      </Grid>
    </Grid>

    <!-- Footer status -->
    <Border Grid.Row="2" Background="#161A24" Padding="24,9">
      <TextBlock x:Name="StatusText" Foreground="#8A90A2" FontSize="12" Text="Ready."/>
    </Border>
  </Grid>
</Window>
